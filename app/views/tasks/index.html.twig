{% extends "layouts/taskBase.html.twig" %}

{% block title %}Tasks{% endblock %}

{% block content %}

    <div class="flex justify-end mb-6">
        <a href="/tasks/create"
           class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg transition">
            Create New Task
        </a>
    </div>

    <div class="bg-white dark:bg-[#0d1117] rounded-xl shadow border border-slate-200 dark:border-[#30363d] overflow-hidden">
        <table class="w-full text-left">
            <thead class="bg-slate-100 dark:bg-[#161b22] text-slate-700 dark:text-slate-300">
            <tr>
                <th class="px-6 py-3 w-1/2">Title</th>
                <th class="px-6 py-3 w-1/4">View</th>
            </tr>
            </thead>

            <tbody class="divide-y divide-slate-200 dark:divide-[#30363d]">
            {% for task in tasks %}
                <tr class="hover:bg-slate-50 dark:hover:bg-[#161b22] transition">
                    <td class="px-6 py-4 font-medium text-slate-900 dark:text-slate-100">
                        {{ task.title }}
                    </td>

                    <td class="px-6 py-4">
                        <a href="/tasks/{{ task.id }}"
                           class="bg-blue-500 hover:bg-blue-600 text-white px-3 py-1 rounded-md text-sm">
                            View
                        </a>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>

{% endblock %}