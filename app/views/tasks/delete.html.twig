{% extends "layouts/taskBase.html.twig" %}

{% block title %}Are you sure you want to delete?{% endblock %}

{% block content %}
    <form method="POST" action="/tasks/{{ task.id }}/delete">
        <div class="bg-white shadow-md rounded-lg overflow-hidden">
            <div class="bg-gray-100 px-6 py-4 border-b">
                <strong class="text-gray-800 text-lg">Delete Task</strong>
            </div>

            <div class="px-6 py-4">
                <p>Are you sure you want to delete the task <strong class="text-gray-900">{{ task.title }}</strong>?</p>
            </div>

            <div class="px-6 py-4 border-t flex space-x-2">
                <button type="submit" class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded">
                    Delete Task
                </button>
            </div>
        </div>
    </form>
{% endblock %}