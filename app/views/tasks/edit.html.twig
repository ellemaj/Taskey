{% extends "layouts/taskBase.html.twig" %}

{% block title %}Edit{% endblock %}

{% block content %}
    <form method="POST" action="/tasks/{{ task.id }}/edit">
        <div class="bg-white shadow-md rounded-lg overflow-hidden">
            <div class="bg-gray-100 px-6 py-4 border-b">
                <strong class="text-gray-800 text-lg">Edit Task</strong>
            </div>

            <div class="px-6 py-4 space-y-4">

                {# Title #}
                <div class="flex items-center">
                    <label for="title" class="w-1/4 font-semibold text-gray-700">Title</label>
                    <div class="w-3/4">
                        <input type="text" id="title" name="title" value="{{ task.title }}"
                               class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                        {% if errors.title %}
                            <div class="text-red-600 text-sm mt-1">{{ errors.title }}</div>
                        {% endif %}
                    </div>
                </div>

                {# Description #}
                <div class="flex items-start">
                    <label for="description" class="w-1/4 font-semibold text-gray-700">Description</label>
                    <div class="w-3/4">
                    <textarea id="description" name="description"
                              class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">{{ task.description }}</textarea>
                        {% if errors.description %}
                            <div class="text-red-600 text-sm mt-1">{{ errors.description }}</div>
                        {% endif %}
                    </div>
                </div>

                {# Priority #}
                <div class="flex items-start">
                    <div class="w-1/4 font-semibold text-gray-700">Priority</div>
                    <div class="w-3/4 space-y-1">
                        {% for value, label in priorities %}
                            <label class="flex items-center space-x-2">
                                <input type="radio" name="priority" value="{{ value }}"
                                       {% if task.priority == value %}checked{% endif %}
                                       class="form-radio text-blue-600">
                                <span>{{ label|capitalize }}</span>
                            </label>
                        {% endfor %}
                        {% if errors.priority %}
                            <div class="text-red-600 text-sm mt-1">{{ errors.priority }}</div>
                        {% endif %}
                    </div>
                </div>

                {# Status #}
                <div class="flex items-center">
                    <label for="status" class="w-1/4 font-semibold text-gray-700">Status</label>
                    <div class="w-3/4">
                        <select name="status" id="status"
                                class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                            {% for value, label in statuses %}
                                <option value="{{ value }}" {% if task.status == value %}selected{% endif %}>
                                    {{ label|title }}
                                </option>
                            {% endfor %}
                        </select>
                        {% if errors.status %}
                            <div class="text-red-600 text-sm mt-1">{{ errors.status }}</div>
                        {% endif %}
                    </div>
                </div>

                {# Progress #}
                <div class="flex items-center">
                    <label for="progress" class="w-1/4 font-semibold text-gray-700">Progress</label>
                    <div class="w-3/4">
                        <input type="range" min="0" max="100" id="progress" name="progress"
                               value="{{ task.progress }}"
                               class="w-full h-2 bg-gray-200 rounded-lg accent-blue-500">
                    </div>
                </div>

                {# Created Date #}
                <div class="flex items-center">
                    <label for="created_at" class="w-1/4 font-semibold text-gray-700">Date Started</label>
                    <div class="w-3/4">
                        <input type="date" id="created_at" name="created_at"
                               value="{{ task.createdAt | date("Y-m-d") }}"
                               class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                </div>

                {# Completed Date #}
                <div class="flex items-center">
                    <label for="completed_at" class="w-1/4 font-semibold text-gray-700">Date Completed</label>
                    <div class="w-3/4">
                        <input type="date" id="completed_at" name="completed_at"
                               {% if task.completedAt %}value="{{ task.completedAt | date("Y-m-d") }}"{% endif %}
                               class="w-full border border-gray-300 rounded px-3 py-2 focus:outline-none focus:ring-2 focus:ring-blue-500">
                    </div>
                </div>

            </div>

            <div class="px-6 py-4 border-t flex space-x-2">
                <input type="submit" value="Save"
                       class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded">
                <a href="/tasks/{{ task.id }}/delete"
                   class="bg-red-600 hover:bg-red-700 text-white px-4 py-2 rounded">
                    Delete Task
                </a>
            </div>
        </div>
    </form>
{% endblock %}